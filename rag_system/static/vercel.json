{
  "version": 2,
  "outputDirectory": ".",
  "buildCommand": "sed -i \"s|__RAILWAY_API_URL__|${RAILWAY_API_URL}|g\" index.html",
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}